# Copia este fichero a .env y ajusta los valores:  cp .env.example .env
# Genera una clave propia, p. ej.:
#   uv run python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esta-clave
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Carpeta raíz donde viven tus proyectos (se escanea recursivamente hasta 3 niveles).
# Admite ~ para tu home, p. ej. ~/Proyectos, ~/code, ~/dev ...
PROJECTS_ROOT=~/Proyectos

# Puerto en el que sirve el dashboard (segunda instancia local, evita el 8000 de Django).
# Lo usa ./run.sh; si falta, cae a 8765.
DASHBOARD_PORT=8765
